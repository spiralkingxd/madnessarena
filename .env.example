# Exemplo de configuração de variáveis de ambiente
# Copie este arquivo para .env e preencha com seus dados

# =============================================================
# FRONTEND (Vite) — Acessíveis via import.meta.env.VITE_*
# =============================================================

# URL do seu projeto Supabase (encontrado em Project Settings > API)
VITE_SUPABASE_URL=https://seu-projeto.supabase.co

# Chave anônima pública do Supabase (encontrada em Project Settings > API)
VITE_SUPABASE_ANON_KEY=sua-chave-anonima-publica

# Discord ID do super-admin (opcional — gerenciado também via banco de dados)
VITE_ADMIN_DISCORD_ID=

# =============================================================
# BACKEND (Node.js / Vercel Serverless) — OBRIGATÓRIAS em produção
# Devem ser configuradas no painel do Vercel em Settings > Environment Variables
# =============================================================

# OBRIGATÓRIO: URL do Supabase (pode ser a mesma que VITE_SUPABASE_URL)
# O servidor lê NEXT_PUBLIC_SUPABASE_URL ou VITE_SUPABASE_URL automaticamente
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co

# OBRIGATÓRIO: Chave de serviço secreta do Supabase (Project Settings > API > service_role)
# NUNCA exponha esta chave no frontend. Apenas no servidor.
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta

# OBRIGATÓRIO: Secret para assinar sessões (qualquer string longa e aleatória)
SESSION_SECRET=gere-uma-string-aleatoria-longa-aqui

# OBRIGATÓRIO: URL pública da sua aplicação (usada para CORS e OAuth redirect)
APP_URL=https://madnessarena.vercel.app

# Credenciais do Discord OAuth2 (Discord Developer Portal > OAuth2)
DISCORD_CLIENT_ID=seu-discord-client-id
DISCORD_CLIENT_SECRET=seu-discord-client-secret
